{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the Flow application.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" }
      },
      "required": ["uid", "email"]
    },
    "HistoryItem": {
      "title": "History Item",
      "description": "A record of a song played by a user, including their emotional feedback.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "videoId": { "type": "string" },
        "title": { "type": "string" },
        "artist": { "type": "string" },
        "emoji": { "type": "string" },
        "rating": { "type": "number" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "videoId", "title", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Stores user profiles."
    },
    "/history/{historyId}": {
      "schema": { "$ref": "#/entities/HistoryItem" },
      "description": "Stores playback history and emotional feedback."
    }
  }
}
